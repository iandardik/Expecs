p-class S {
    var x : String = "none"
    var state : String = "A"

    action PromptUser(msg : String) {
        guard:
            state = "A" & msg = "Enter a message:"
        update:
            state := "B"
    }
    
    action Readln(msg : String) {
        guard:
            state = "B"
        update:
            x := msg
            state := "C"
    }

    action Println(msg : String) {
        guard:
            (state = "C") & (msg = x) & ~(x = "done")
        update:
            state := "A"
    }
}

