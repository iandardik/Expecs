p-class S {
    var x : Int = 0
    var p : String = "false"
    
    action ReadlnInt(msg : Int) {
        guard:
            p = "false"
        update:
            x := x + msg
            p := "true"
    }

    action PrintlnInt(msg : Int) {
        guard:
            (p = "true") & (msg = x)
        update:
            p := "false"
    }
}

