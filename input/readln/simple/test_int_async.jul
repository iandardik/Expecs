p-class S {
    var x : Int = 0
    var p : Bool = false
    
    action ReadlnInt(msg : Int) {
        guard:
            ~p
        update:
            x := x + msg
            p := true
    }

    action PrintlnInt(msg : Int) {
        guard:
            p & (msg = x)
        update:
            p := false
    }
}

