p-class S {
    var x : Int = 0
    var state : String = "A"

    action PromptUserInt(msg : String) {
        guard:
            state = "A"
        update:
            state := "B"
    }
    
    action ReadlnInt(msg : Int) {
        guard:
            state = "B"
        update:
            x := x + msg
            state := "C"
    }

    action PrintlnInt(msg : Int) {
        guard:
            (state = "C") & (msg = x)
        update:
            state := "A"
    }
}

