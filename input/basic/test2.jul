p-class S {
    var x : String = "noneS"
    var p : String = "true"
    var c : Int = 0
    
    action I(msg : String) {
        guard:
            (msg = x) & (p = "false")
        update:
            x := msg
            p := "true"
    }

    action Println(msg : String) {
        guard:
            (p = "true") & (msg = x) & (c <= 10)
        update:
            p := "false"
            c := c + 1
    }
}

p-class T {
    var y : String = "noneT"
    var d : Int = 0

    action I(msg : String) {
        guard:
            d <= 10
        update:
            y := msg
            d := d + 1
    }
}
