p-class S {
    var x : Int = 0
    var p : String = "true"
    
    action I(inc : Int) {
        guard:
            (x <= 10) & (inc > 0) & (p = "false")
        update:
            x := x + inc
            p := "true"
    }

    action Println(msg : Int) {
        guard:
            (p = "true") & (msg = x)
        update:
            p := "false"
    }
}

p-class T {
    var y : Int = 0

    action I(inc : Int) {
        guard:
            inc > 3 & y <= 10
        update:
            y := y + inc
    }
}
