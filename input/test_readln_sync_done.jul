p-class S {
    var x : Int = 0
    var state : String = "A"
    var prev : Int = 0

    action PromptUser() {
        guard:
            state = "A"
        update:
            state := "B"
    }
    
    action Readln(msg : Int) {
        guard:
            state = "B"
        update:
            x := x + msg
            state := "C"
            prev := msg
    }

    action Println(msg : Int) {
        guard:
            (state = "C") & (msg = x) & (prev >= 0)
        update:
            state := "A"
    }
}

